{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"cache": true,
			"outputs": ["dist/**", ".next/**", "storybook-static/**"]
		},
		"lint:biome": {
			"cache": true,
			"inputs": ["src/**", "*.json", "*.config.*", "biome.json"]
		},
		"typecheck": {
			"cache": true,
			"inputs": ["src/**", "*.json", "tsconfig.json"]
		},
		"test": {
			"cache": true,
			"outputs": ["test-results/**", "coverage/**"],
			"inputs": [
				"src/**",
				"*.json",
				"*.config.*",
				"test/**",
				"vitest.*.ts",
				".storybook-interaction/**"
			]
		},
		"test:unit": {
			"cache": true,
			"outputs": ["test-results/**"],
			"inputs": ["src/**", "*.json", "*.config.*", "test/**", "vitest.*.ts"]
		},
		"test:interaction": {
			"cache": true,
			"outputs": ["test-results/**"],
			"inputs": ["src/**", ".storybook-interaction/**", "*.config.*"]
		},
		"build-storybook": {
			"cache": true,
			"outputs": ["storybook-static/**"],
			"inputs": ["src/**", ".storybook/**", "*.config.*", "*.stories.*"]
		},
		"vrt:yaboujee": {
			"cache": true,
			"outputs": [
				"suites/**/test-results/**",
				"suites/**/playwright-report/**",
				"**/__snapshots__/**"
			],
			"inputs": ["**/*.ts", "**/*.tsx", "**/*.stories.*", "scripts/**"]
		},
		"vrt:yaboujee:update": {
			"cache": true,
			"outputs": [
				"suites/**/test-results/**",
				"suites/**/playwright-report/**",
				"**/__snapshots__/**"
			],
			"inputs": ["**/*.ts", "**/*.tsx", "**/*.stories.*", "scripts/**"]
		},
		"vrt:frontend": {
			"cache": true,
			"outputs": [
				"suites/**/test-results/**",
				"suites/**/playwright-report/**",
				"**/__snapshots__/**"
			],
			"inputs": ["**/*.ts", "**/*.tsx", "**/*.stories.*", "scripts/**"]
		},
		"vrt:frontend:update": {
			"cache": true,
			"outputs": [
				"suites/**/test-results/**",
				"suites/**/playwright-report/**",
				"**/__snapshots__/**"
			],
			"inputs": ["**/*.ts", "**/*.tsx", "**/*.stories.*", "scripts/**"]
		},
		"test:e2e": {
			"cache": true,
			"outputs": ["test-results/**", "playwright-report/**"],
			"inputs": ["**/*.ts", "**/*.tsx", "playwright/**", "e2e/**"]
		}
	}
}
